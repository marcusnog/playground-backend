// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model FormaPagamento {
  id        String @id @default(uuid())
  descricao String
  status    String // 'ativo' | 'inativo'
  pixChave  String?
  pixConta  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lancamentos            Lancamento[]
  lancamentosEstacionamento LancamentoEstacionamento[]
}

model Cortesia {
  id             String   @id @default(uuid())
  codigo         String   @unique
  usado          Boolean  @default(false)
  lancamentoId   String?
  clienteId      String?
  whatsappDestino String
  validadeDias   Int
  createdAt      DateTime @default(now())

  cliente        Cliente? @relation(fields: [clienteId], references: [id])

  @@index([codigo])
}

model Brinquedo {
  id                     String  @id @default(uuid())
  nome                   String
  inicialMinutos         Int?    // null = taxa única sem limite
  valorInicial           Float
  cicloMinutos           Int?    // null = não usa ciclos
  valorCiclo             Float
  cicloToleranciaMinutos Int?    // min de tolerância no início de cada ciclo
  valorCiclo2            Float?  // valor por ciclo na 2ª faixa (após cicloTier2Minutos total)
  cicloTier2Minutos      Int?    // minutos totais a partir dos quais entra na 2ª faixa de preço
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  lancamentos            Lancamento[]
  caixas                 CaixaBrinquedo[]
}

model Parametros {
  id                    String  @id @default("global")
  valorInicialMinutos   Int
  valorInicialReais     Float
  valorCicloMinutos     Int
  valorCicloReais       Float
  cicloToleranciaMinutos Int?   // min de tolerância no início de cada ciclo (0 = cobra imediatamente)
  empresaNome           String?
  empresaCnpj           String?
  empresaLogoUrl        String?
  pixChave              String?
  pixCidade             String?
  updatedAt             DateTime @updatedAt
}

model Caixa {
  id          String  @id @default(uuid())
  nome        String
  data        String  // ISO date string
  valorInicial Float
  status      String  // 'aberto' | 'fechado'
  bloqueado   Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  movimentos          MovimentoCaixa[]
  usuarios            Usuario[]
  estacionamentos     Estacionamento[]
  brinquedos          CaixaBrinquedo[]
  aberturas           CaixaAbertura[]
}

model CaixaBrinquedo {
  caixaId    String
  brinquedoId String
  caixa      Caixa    @relation(fields: [caixaId], references: [id], onDelete: Cascade)
  brinquedo  Brinquedo @relation(fields: [brinquedoId], references: [id], onDelete: Cascade)
  @@id([caixaId, brinquedoId])
}

model MovimentoCaixa {
  id        String   @id @default(uuid())
  caixaId   String
  caixaAberturaId String?
  dataHora  DateTime
  tipo      String   // 'sangria' | 'suprimento'
  valor     Float
  motivo    String?
  createdAt DateTime @default(now())

  caixa     Caixa    @relation(fields: [caixaId], references: [id], onDelete: Cascade)
  caixaAbertura CaixaAbertura? @relation(fields: [caixaAberturaId], references: [id], onDelete: SetNull)
}

model Cliente {
  id                String   @id @default(uuid())
  nomeCompleto      String
  dataNascimento    String   // ISO date
  nomePai           String
  nomeMae           String
  telefoneWhatsapp  String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  lancamentos       Lancamento[]
  cortesias         Cortesia[]
}

model Lancamento {
  id                  String   @id @default(uuid())
  dataHora            DateTime
  nomeCrianca         String
  nomeResponsavel     String
  tipoParente         String?  // pai, mae, avo, ava, tio, tia, outro
  whatsappResponsavel String
  numeroPulseira      String?
  criancasAdicionaisJson String?  // JSON: [{nomeCrianca: string, numeroPulseira?: string}]
  tempoSolicitadoMin  Int?     // null -> Tempo Livre ou modo quantidade
  tempoInicialMin     Int?     // minutos do bloco inicial
  tempoAdicionalMin   Int?     // minutos adicionais (total = tempoInicialMin + tempoAdicionalMin)
  quantidade          Int?     // número de pulseiras (modo TRENZINHO/INFLÁVEL)
  brinquedoId         String?
  clienteId           String?
  status              String   // 'aberto' | 'pago' | 'cancelado'
  valorCalculado      Float
  valorDesconto       Float?   // valor do desconto aplicado (dos acréscimos)
  valorRecebido       Float?   // valor recebido em dinheiro (para cálculo do troco)
  formaPagamentoId    String?
  pagamentosJson      String?  // JSON com múltiplas formas (formaPagamentoId/descricao/valor)
  caixaAberturaId     String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  brinquedo           Brinquedo?        @relation(fields: [brinquedoId], references: [id])
  cliente             Cliente?          @relation(fields: [clienteId], references: [id])
  formaPagamento      FormaPagamento?   @relation(fields: [formaPagamentoId], references: [id])
  caixaAbertura       CaixaAbertura?    @relation(fields: [caixaAberturaId], references: [id], onDelete: SetNull)
}

model Usuario {
  id                  String   @id @default(uuid())
  nomeCompleto        String
  apelido             String   @unique
  contato             String
  senha               String   // Hash bcrypt
  usaCaixa            Boolean  @default(false)
  caixaId             String?
  bloqueado           Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Permissões
  acompanhamento      Boolean  @default(false)
  lancamento          Boolean  @default(false)
  caixaAbertura       Boolean  @default(false)
  caixaFechamento     Boolean  @default(false)
  caixaSangria        Boolean  @default(false)
  caixaSuprimento     Boolean  @default(false)
  estacionamentoCadastro Boolean @default(false)
  estacionamentoCaixaAbertura Boolean @default(false)
  estacionamentoCaixaFechamento Boolean @default(false)
  estacionamentoLancamento Boolean @default(false)
  estacionamentoAcompanhamento Boolean @default(false)
  relatorios          Boolean  @default(false)
  parametrosEmpresa   Boolean  @default(false)
  parametrosFormasPagamento Boolean @default(false)
  parametrosBrinquedos Boolean @default(false)
  clientes            Boolean  @default(false)
  autorizarCancelamentosEDescontos Boolean @default(false) // pode autorizar cancelamentos sem cobrança e descontos em pagamentos
  cortesia            Boolean  @default(false)  // pode gerar códigos de cortesia

  caixa               Caixa?   @relation(fields: [caixaId], references: [id])
  caixasAbertas       CaixaAbertura[] @relation("UsuarioAberturas")
  caixasFechadas      CaixaAbertura[] @relation("UsuarioFechamentos")
}

model Estacionamento {
  id        String   @id @default(uuid())
  nome      String
  caixaId   String
  valor     Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  caixa     Caixa    @relation(fields: [caixaId], references: [id], onDelete: Cascade)
  lancamentos LancamentoEstacionamento[]
}

model LancamentoEstacionamento {
  id                String   @id @default(uuid())
  estacionamentoId  String
  placa             String
  modelo            String?
  telefoneContato   String?
  dataHora          DateTime
  valor             Float
  formaPagamentoId  String?
  status            String   // 'aberto' | 'pago' | 'cancelado'
  caixaAberturaId   String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  estacionamento    Estacionamento  @relation(fields: [estacionamentoId], references: [id], onDelete: Cascade)
  formaPagamento    FormaPagamento? @relation(fields: [formaPagamentoId], references: [id])
  caixaAbertura     CaixaAbertura?  @relation(fields: [caixaAberturaId], references: [id], onDelete: SetNull)
}

model CaixaAbertura {
  id                  String   @id @default(uuid())
  caixaId             String
  usuarioAberturaId   String
  usuarioFechamentoId String?
  dataAbertura        DateTime
  dataFechamento      DateTime?
  valorInicial        Float
  status              String   // 'aberto' | 'fechado'
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  caixa               Caixa    @relation(fields: [caixaId], references: [id], onDelete: Cascade)
  usuarioAbertura     Usuario  @relation("UsuarioAberturas", fields: [usuarioAberturaId], references: [id])
  usuarioFechamento   Usuario? @relation("UsuarioFechamentos", fields: [usuarioFechamentoId], references: [id])
  movimentos          MovimentoCaixa[]
  lancamentos         Lancamento[]
  lancamentosEstacionamento LancamentoEstacionamento[]

  @@index([caixaId, status])
  @@index([dataAbertura])
  @@index([usuarioAberturaId])
  @@index([usuarioFechamentoId])
}

