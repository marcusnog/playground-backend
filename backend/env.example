# Ambiente (development | production)
NODE_ENV=development

# Porta do servidor
PORT=3001

# JWT Secret (OBRIGATÓRIO - use uma string aleatória forte em produção)
# Para gerar: openssl rand -base64 48
# ATENÇÃO: Em produção, qualquer valor padrão ou com menos de 32 chars encerrará o servidor com erro
JWT_SECRET=<gere-com-openssl-rand-base64-48>

# Senha do PostgreSQL (OBRIGATÓRIO quando usar docker-compose)
# Para gerar: openssl rand -base64 32
POSTGRES_PASSWORD=<gere-com-openssl-rand-base64-32>

# Database URL (OBRIGATÓRIO)
# PostgreSQL (recomendado para desenvolvimento e produção):
DATABASE_URL="postgresql://user:password@localhost:5432/playground?schema=public"

# SQLite (apenas para desenvolvimento local rápido - não funciona no Render):
# DATABASE_URL="file:./data/dev.db"

# CORS Origin (opcional - separar múltiplas origens por vírgula)
# Em produção, defina as origens permitidas:
# CORS_ORIGIN=https://seusite.com,https://www.seusite.com
# Deixe vazio em desenvolvimento para permitir todas as origens
CORS_ORIGIN=


# Anthropic API Key (opcional - para o Assistente IA)
# Obtenha em: https://console.anthropic.com
ANTHROPIC_API_KEY=
